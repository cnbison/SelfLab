# SGE M1.1 环境变量配置示例
# ====================================================================
# 使用方法:
#   1. 复制此文件: cp .env.example .env
#   2. 编辑 .env 填入实际值
#   3. .env 已被 .gitignore 排除（不会被提交）
# ====================================================================

# ===== LLM 提供商配置 =====
# MiniMax-M3 提供商（Anthropic 兼容协议）
# 在 https://api.minimax.io 订阅后获取 API Key
MINIMAX_API_KEY=your-minimax-api-key-here

# ===== 实验配置 =====
# 实验输出目录（默认: experiments/output/）
# SGE_OUTPUT_DIR=experiments/output/

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
# SGE_LOG_LEVEL=INFO
